{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/sse-events-v2.schema.json",
  "title": "ShanHaiEdu SSE Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "event_type", "occurred_at", "status", "progress", "message", "data"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "pattern": "^(workflow\\.node|generation\\.job|creation\\.batch|artifact|asset|ppt|video|delivery|system\\.notification)\\.[a-z0-9_.-]+$"
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "organization_id": { "type": ["string", "null"] },
    "project_id": { "type": ["string", "null"] },
    "lesson_id": { "type": ["string", "null"] },
    "node_run_id": { "type": ["string", "null"] },
    "job_id": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "progress": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
    "message": { "type": "string" },
    "data": { "type": "object", "additionalProperties": true }
  }
}
