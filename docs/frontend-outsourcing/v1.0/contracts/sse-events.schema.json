{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/sse-events-v1.schema.json",
  "title": "ShanHaiEdu SSE Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "event_type", "occurred_at", "project_id", "payload"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "enum": [
        "task.queued",
        "task.started",
        "task.progress",
        "task.completed",
        "task.failed",
        "task.cancelled",
        "node.status_changed",
        "artifact.version_created",
        "artifact.approved",
        "budget.updated",
        "provider.degraded"
      ]
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "organization_id": { "type": ["string", "null"] },
    "project_id": { "type": "string", "minLength": 1 },
    "lesson_id": { "type": ["string", "null"] },
    "node_key": { "type": ["string", "null"] },
    "task_id": { "type": ["string", "null"] },
    "payload": { "type": "object", "additionalProperties": true }
  }
}

