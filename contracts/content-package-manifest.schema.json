{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/content-package-manifest.schema.json",
  "title": "ContentPackageManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "package_key",
    "name",
    "semantic_version",
    "runtime_constraint",
    "change_summary",
    "items",
    "entrypoints"
  ],
  "properties": {
    "format_version": {"const": "1.0"},
    "package_key": {"$ref": "#/$defs/key"},
    "name": {"type": "string", "minLength": 1, "maxLength": 255},
    "semantic_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "runtime_constraint": {"type": "string", "minLength": 1, "maxLength": 120},
    "change_summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "dependencies": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package_key", "version_constraint"],
        "properties": {
          "package_key": {"$ref": "#/$defs/key"},
          "version_constraint": {"type": "string", "minLength": 1, "maxLength": 120}
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/item"}
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/key"}
    }
  },
  "$defs": {
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
    "kind": {
      "enum": [
        "input_definition",
        "content_definition",
        "style_preset",
        "prompt_template",
        "projection_template",
        "generation_template"
      ]
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9._/-]+\\.json$"
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind", "path", "schema_id", "sha256"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"$ref": "#/$defs/kind"},
        "path": {"$ref": "#/$defs/safePath"},
        "schema_id": {"type": "string", "format": "uri"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
