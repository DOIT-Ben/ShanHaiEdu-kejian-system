{
  "api_version": "shanhai.edu/v1",
  "kind": "input_definition",
  "metadata": {
    "key": "audio.tts.generate.input",
    "name": "TTS配音生成输入",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "definition_key": "audio.tts.generate.input",
    "title": "TTS配音生成输入",
    "description": "输入一个TTS音频计划项、候选数和可选声音参考。",
    "fields": [
      {
        "field_key": "tts_audio_plan_item_ref",
        "label": "TTS计划项",
        "value_type": "reference",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "textarea"
      },
      {
        "field_key": "tts_candidate_count",
        "label": "候选数量",
        "value_type": "number",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "number",
        "default_value": 1,
        "validation": {
          "minimum": 1,
          "maximum": 3
        }
      },
      {
        "field_key": "tts_voice_reference",
        "label": "声音参考",
        "value_type": "asset",
        "required": false,
        "source": "system",
        "visibility": "advanced",
        "widget": "asset_picker"
      },
      {
        "field_key": "tts_generation_quality",
        "label": "逻辑质量档位",
        "value_type": "enum",
        "required": true,
        "source": "teacher",
        "visibility": "secondary",
        "widget": "select",
        "default_value": "balanced",
        "options": [
          {
            "value": "fast",
            "label": "快速"
          },
          {
            "value": "balanced",
            "label": "均衡"
          },
          {
            "value": "quality",
            "label": "高质量"
          }
        ]
      }
    ]
  }
}
