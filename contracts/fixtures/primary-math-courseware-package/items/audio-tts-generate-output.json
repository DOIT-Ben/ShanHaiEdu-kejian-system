        "type": "reference",
        "required": true,
        "editable": false,
        "deletable": false
      },
      {
        "field_key": "tts_target_slot",
        "label": "目标槽位",
        "type": "text",
        "required": true,
        "editable": false,
        "deletable": false
      },
      {
        "field_key": "tts_candidates",
        "label": "配音候选",
        "type": "repeatable",
        "required": true,
        "editable": false,
        "deletable": false,
        "repeatable": true,
        "min_items": 1,
        "children": [
          {
            "field_key": "tts_result_key",
