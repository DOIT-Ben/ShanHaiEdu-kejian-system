{
  "api_version": "shanhai.edu/v1",
  "kind": "input_definition",
  "metadata": {
    "key": "video.shots.generate.input",
    "name": "课堂导入短片候选生成输入",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "definition_key": "video.shots.generate.input",
    "title": "课堂导入短片候选生成输入",
    "description": "输入exact导入选择、唯一正式关键帧、固定6秒时长、单候选和发布内固定风格。",
    "fields": [
      {
        "field_key": "selected_intro_ref",
        "label": "已选导入方案",
        "value_type": "reference",
        "required": true,
        "source": "context",
        "visibility": "hidden",
        "widget": "textarea"
      },
      {
        "field_key": "shot_candidate_count",
        "label": "候选数量",
        "value_type": "number",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "number",
        "default_value": 1,
        "validation": {
          "minimum": 1,
          "maximum": 1
        }
      },
      {
        "field_key": "shot_duration_seconds",
        "label": "短片时长",
        "value_type": "number",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "number",
        "default_value": 6,
        "validation": {
          "minimum": 6,
          "maximum": 6
        }
      },
      {
        "field_key": "shot_reference_assets",
        "label": "唯一关键帧",
        "value_type": "asset",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "asset_picker"
      },
      {
        "field_key": "shot_style_preset",
        "label": "固定视频风格",
        "value_type": "reference",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "style_picker",
        "default_value": "style.primary_math.paper_clay",
        "allowed_item_kinds": [
          "style_preset"
        ]
      }
    ]
  }
}
