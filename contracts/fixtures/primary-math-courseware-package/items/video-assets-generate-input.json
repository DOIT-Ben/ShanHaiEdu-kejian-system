{
  "api_version": "shanhai.edu/v1",
  "kind": "input_definition",
  "metadata": {
    "key": "video.assets.generate.input",
    "name": "视频四类图片资产生成输入",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "definition_key": "video.assets.generate.input",
    "title": "视频四类图片资产生成输入",
    "description": "输入不可变图片任务包、视频风格合同、候选数和必需视觉母图参考。",
    "fields": [
      {
        "field_key": "video_asset_creation_package_ref",
        "label": "视频资产图片任务包",
        "value_type": "reference",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "textarea"
      },
      {
        "field_key": "video_asset_candidates_per_item",
        "label": "每项候选数",
        "value_type": "number",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "number",
        "default_value": 2,
        "validation": {
          "minimum": 1,
          "maximum": 4
        }
      },
      {
        "field_key": "video_asset_generation_quality",
        "label": "逻辑质量档位",
        "value_type": "enum",
        "required": true,
        "source": "teacher",
        "visibility": "secondary",
        "widget": "select",
        "default_value": "balanced",
        "options": [
          {
            "value": "fast",
            "label": "快速"
          },
          {
            "value": "balanced",
            "label": "均衡"
          },
          {
            "value": "quality",
            "label": "高质量"
          }
        ]
      },
      {
        "field_key": "video_style_master_asset",
        "label": "视觉母图参考",
        "value_type": "asset",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "asset_picker"
      }
    ]
  }
}
