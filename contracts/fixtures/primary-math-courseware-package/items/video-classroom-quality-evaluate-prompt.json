{
  "api_version": "shanhai.edu/v1",
  "kind": "prompt_template",
  "metadata": {
    "key": "video.classroom_quality.evaluate.prompt",
    "name": "视频课堂质量评估业务Prompt",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "template_key": "video.classroom_quality.evaluate.prompt",
    "title": "视频课堂质量评估业务Prompt",
    "description": "以最终视频和已选导入快照评估独立创意、交接、不得提前讲授、连续性和课堂可用性。",
    "model_capability": "vision.evaluate.classroom_video",
    "input_definition_ref": {
      "item_key": "video.classroom_quality.evaluate.input",
      "kind": "input_definition"
    },
    "output_definition_ref": {
      "item_key": "video.classroom_quality.evaluate.output",
      "kind": "content_definition"
    },
    "sections": [
      {
        "section_key": "role",
        "layer": "role",
        "content": "你是课堂导入视频的独立质量评估员，按已选导入方案快照检查最终视频。",
        "editable": false,
        "visible_to_teacher": true
      },
      {
        "section_key": "task",
        "layer": "task",
        "content": "观看最终视频并评估独立创意是否成立、是否准确继承钩子、是否在唯一handoff_moment交接、是否没有提前讲授、视觉动作是否连续、是否适合真实课堂。所有问题给出时间区间和受影响shot。",
        "editable": true,
        "visible_to_teacher": true
      },
      {
        "section_key": "method",
        "layer": "method",
        "content": "以已选方案快照为唯一课程语义基准，不读取教案、教材或PPT。逐段比较independent_concept、hook、course_anchor、classroom_first_question、handoff_moment和must_not_preteach；同时检查画面可读性、节奏、儿童安全、连续性、字幕音频同步和课堂暂停点。分项评分并按阈值给出通过结论。",
        "editable": false,
        "visible_to_teacher": false
      },
      {
        "section_key": "quality_gate",
        "layer": "quality_gate",
        "content": "不得因个人审美改写上游创意；所有失败有可定位证据；任何提前讲授、越过交接、严重安全问题或不可播放都必须阻塞通过；发现只指向受影响shot，不要求无关镜头重做；报告不包含Provider、密钥或原始敏感模型响应。",
        "editable": false,
        "visible_to_teacher": false
      }
    ],
    "context_bindings": [
      {
        "binding_key": "selected_intro",
        "source": "intro_selection.snapshot",
        "required": true,
        "exposure": "full",
        "max_items": 1,
        "max_bytes": 100000
      }
    ],
    "user_edit_policy": {
      "mode": "replace_editable_layer",
      "max_chars": 30000
    }
  }
}
