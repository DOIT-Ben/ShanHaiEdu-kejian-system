      {
        "field_key": "cover_composition",
        "label": "构图与留白",
        "type": "rich_text",
        "required": true,
        "editable": true,
        "deletable": false
      },
      {
        "field_key": "cover_material_and_form",
        "label": "材质与造型",
        "type": "rich_text",
        "required": true,
        "editable": true,
        "deletable": false
      },
      {
        "field_key": "cover_palette_and_lighting",
