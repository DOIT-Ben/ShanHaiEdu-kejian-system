{
  "api_version": "shanhai.edu/v1",
  "kind": "prompt_template",
  "metadata": {
    "key": "intro.anchor.prompt",
    "name": "最小课程锚定业务Prompt",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "template_key": "intro.anchor.prompt",
    "title": "最小课程锚定业务Prompt",
    "description": "只为一套或九套独立创意补充唯一最小课程锚点、首问、交接和推荐度，不改写独立创意。",
    "model_capability": "text.structured.zh_primary_math",
    "input_definition_ref": {
      "item_key": "intro.anchor.input",
      "kind": "input_definition"
    },
    "output_definition_ref": {
      "item_key": "intro.anchor.output",
      "kind": "content_definition"
    },
    "sections": [
      {
        "section_key": "role",
        "layer": "role",
        "content": "你是小学数学课堂导入锚定设计师，负责把已经成立的独立创意最小化地接回一个已批准课时。",
        "editable": false,
        "visible_to_teacher": true
      },
      {
        "section_key": "task",
        "layer": "task",
        "content": "逐套保留独立创意的标题、独立概念、钩子和观看价值，只补一个课程锚点、课堂第一问、交接时刻、不得提前讲授、适配理由、风险和推荐分。不得重写独立创意，不得生成分镜、旁白、字幕、资产或模型参数。",
        "editable": true,
        "visible_to_teacher": true
      },
      {
        "section_key": "method",
        "layer": "method",
        "content": "先从批准课时与教材证据提取当前核心学习边界和不得提前讲授内容。对每套创意找到一个具体的触发事件、可见现象、真实选择或未完成行动作为唯一回接；锚点只负责把注意力带回课堂，不解释整节课。交接时刻必须可定位，课堂第一问必须可直接由教师提出。推荐度综合独立性、课时适配、可制作性、时长和风险；default_nine必须产生唯一最高值，refine_existing只有一套并保留教师选择。",
        "editable": false,
        "visible_to_teacher": false
      },
      {
        "section_key": "quality_gate",
        "layer": "quality_gate",
        "content": "default_nine科普、应用、故事各恰好三套，refine_existing恰好一套；独立创意字段与上游逐字一致；每套只有一个课程锚点，且去掉锚点仍成立；不得提前讲出需要学生发现的定义、写法、方法或结论；default_nine最高推荐分必须唯一；不得因为小学受众默认教师、教室或儿童角色；输出不含教案正文、PPT、分镜、旁白、字幕、资产、Provider和费用。",
        "editable": false,
        "visible_to_teacher": false
      }
    ],
    "context_bindings": [
      {
        "binding_key": "approved_lesson_unit",
        "source": "lesson_division.approved_version",
        "required": true,
        "exposure": "full",
        "max_items": 1,
        "max_bytes": 200000
      },
      {
        "binding_key": "approved_material",
        "source": "material.approved_parse",
        "required": true,
        "exposure": "summary",
        "max_items": 50,
        "max_bytes": 300000
      }
    ],
    "user_edit_policy": {
      "mode": "replace_editable_layer",
      "max_chars": 40000
    }
  }
}
