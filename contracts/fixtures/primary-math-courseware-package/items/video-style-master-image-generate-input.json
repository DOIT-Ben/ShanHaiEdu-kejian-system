{
  "api_version": "shanhai.edu/v1",
  "kind": "input_definition",
  "metadata": {
    "key": "video.style_master.image.generate.input",
    "name": "视频视觉母图生成输入",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "definition_key": "video.style_master.image.generate.input",
    "title": "视频视觉母图生成输入",
    "description": "输入视觉母图完整指令、候选数、目标槽位和可选风格参考。",
    "fields": [
      {
        "field_key": "style_master_prompt_text",
        "label": "视觉母图完整指令",
        "value_type": "rich_text",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "textarea",
        "validation": {
          "min_length": 20,
          "max_length": 25000
        }
      },
      {
        "field_key": "style_master_generation_count",
        "label": "候选数",
        "value_type": "number",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "number",
        "default_value": 3,
        "validation": {
          "minimum": 2,
          "maximum": 4
        }
      },
      {
        "field_key": "style_master_generation_slot",
        "label": "目标槽位",
        "value_type": "text",
        "required": true,
        "source": "system",
        "visibility": "hidden",
        "widget": "text"
      },
      {
        "field_key": "style_master_reference_assets",
        "label": "风格参考",
        "value_type": "asset",
        "required": false,
        "source": "system",
        "visibility": "advanced",
        "widget": "asset_picker"
      }
    ]
  }
