{
  "api_version": "shanhai.edu/v1",
  "kind": "input_definition",
  "metadata": {
    "key": "image_prompt.input",
    "name": "教育插画需求输入",
    "domain": "primary_math",
    "locale": "zh-CN"
  },
  "spec": {
    "definition_key": "image_prompt.input",
    "title": "教育插画需求输入",
    "description": "教师只填写画面内容并选择风格，专业字段由系统和上下文补全。",
    "fields": [
      {
        "field_key": "content",
