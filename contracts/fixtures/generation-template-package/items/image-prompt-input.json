        "value_type": "rich_text",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "textarea",
        "validation": {"min_length": 5, "max_length": 2000}
      },
      {
        "field_key": "style_preset",
        "label": "画面风格",
        "value_type": "reference",
        "required": true,
        "source": "teacher",
        "visibility": "primary",
        "widget": "style_picker",
        "allowed_item_kinds": ["style_preset"]
      },
      {
        "field_key": "lesson_context",
        "label": "课程上下文",
        "value_type": "rich_text",
        "required": false,
        "source": "context",
        "visibility": "hidden",
        "widget": "textarea"
      }
    ]
  }
