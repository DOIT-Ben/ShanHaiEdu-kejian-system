{
  "schema_version": "1.0",
  "scenarios": [
    {"id": "project_empty", "route": "/app/projects/:project_id", "description": "教材尚未上传的项目主页"},
    {"id": "lesson_plan_edit", "route": "/app/projects/:project_id/lessons/:lesson_id/work/lesson-plan", "description": "动态十二部分默认教案，可增删允许字段"},
    {"id": "intro_options", "route": "/app/projects/:project_id/lessons/:lesson_id/work/intro-options", "description": "三类九套打分、独立审核和选择；不阻塞教案"},
    {"id": "prompt_review", "route": "/app/projects/:project_id/lessons/:lesson_id/work/:step_key", "description": "系统提示词可见、教师修改、输出审核"},
    {"id": "node_running", "route": "/app/projects/:project_id/lessons/:lesson_id/work/:step_key", "description": "异步任务运行且刷新后恢复"},
    {"id": "node_partial", "route": "/app/projects/:project_id/lessons/:lesson_id/work/:step_key", "description": "批量页面或镜头部分成功"},
    {"id": "node_stale", "route": "/app/projects/:project_id/lessons/:lesson_id/work/:step_key", "description": "上游批准新版后的局部影响与三种处理"},
    {"id": "creation_independent", "route": "/app/creation/images", "description": "不绑定项目的独立图片创作"},
    {"id": "creation_from_package", "route": "/app/creation/batches/:batch_id", "description": "项目包批量导入、生成并保存回项目"},
    {"id": "save_conflict", "route": "/app/creation/batches/:batch_id", "description": "目标单值槽位已存在，选择替换或另存"},
    {"id": "sse_recovery", "route": "/app/tasks", "description": "事件断线、游标续传、REST 对账"},
    {"id": "budget_pause", "route": "/app/projects/:project_id", "description": "全自动因预算确认暂停"},
    {"id": "admin_content_publish", "route": "/admin/content", "description": "内容包导入、校验、评测和发布"}
  ]
}
