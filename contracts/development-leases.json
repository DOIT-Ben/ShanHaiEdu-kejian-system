{
  "$schema": "./development-leases.schema.json",
  "lease_version": "shanhai.development-leases/v1",
  "shared_contract_paths": [
    "contracts/api-surface.openapi.yaml",
    "contracts/planned-api-surface.openapi.yaml",
    "contracts/generated/**",
    "contracts/full-chain-freeze.json",
    "contracts/full-chain-freeze.schema.json",
    "contracts/page-api-fact-matrix.json",
    "contracts/page-api-fact-matrix.schema.json",
    "contracts/development-leases.json",
    "contracts/development-leases.schema.json",
    "contracts/fixtures/workflow-node-generation-bindings/**",
    "contracts/fixtures/primary-math-courseware-package/**",
    "workflow/builtin/primary_math_courseware/**",
    "workflow/definition/**",
    "apps/api/node_execution/**",
    "apps/api/artifacts/**",
    "apps/api/model_gateway/**"
  ],
  "change_process": {
    "request": "open_contract_change",
    "owner_update": "merge_shared_contract_first",
    "consumer_resume": "rebase_then_continue"
  },
  "tracks": [
    {
      "track_key": "shared_contract",
      "role": "Single writer for active/planned OpenAPI, generated client, immutable content releases, workflow binding, shared Artifact/Job semantics and freeze gates.",
      "writable": [
        ".github/workflows/contract-freeze.yml",
        ".github/workflows/development-lease.yml",
        "contracts/README.md",
        "contracts/api-surface.openapi.yaml",
        "contracts/planned-api-surface.openapi.yaml",
        "contracts/generated/**",
        "contracts/full-chain-freeze.json",
        "contracts/full-chain-freeze.schema.json",
        "contracts/page-api-fact-matrix.json",
        "contracts/page-api-fact-matrix.schema.json",
        "contracts/development-leases.json",
        "contracts/development-leases.schema.json",
        "contracts/fixtures/contract-freeze/**",
        "contracts/fixtures/parallel-inputs/**",
        "contracts/fixtures/workflow-node-generation-bindings/**",
        "contracts/fixtures/primary-math-courseware-package/**",
        "workflow/builtin/primary_math_courseware/**",
        "workflow/definition/**",
        "apps/api/node_execution/**",
        "apps/api/artifacts/**",
        "apps/api/model_gateway/**",
        "package.json",
        "scripts/check_contract_freeze.py",
        "scripts/check_development_lease.py",
        "scripts/check_parallel_fixtures.py",
        "scripts/check_contracts.sh",
        "tests/contract/test_contract_freeze.py",
        "tests/contract/test_development_lease.py",
        "tests/contract/test_parallel_fixtures.py",
        "docs/governance/CONTRACT_FREEZE.md"
      ],
      "readonly": [
        "apps/web/**",
        "apps/api/ppt_runtime/**",
        "apps/api/video_runtime/**",
        "apps/api/lessons/**"
      ],
      "forbidden": [],
      "contract_change_required": false
    },
    {
      "track_key": "frontend",
      "role": "Production UI and generated-client consumer; no server contract ownership.",
      "writable": ["apps/web/**"],
      "readonly": [
        "contracts/api-surface.openapi.yaml",
        "contracts/generated/**",
        "contracts/full-chain-freeze.json",
        "contracts/page-api-fact-matrix.json",
        "contracts/fixtures/contract-freeze/**"
      ],
      "forbidden": [
        "contracts/planned-api-surface.openapi.yaml",
        "workflow/**",
        "apps/api/**",
        "workers/**",
        "alembic/**"
      ],
      "contract_change_required": true
    },
    {
      "track_key": "ppt",
      "role": "Complete PPT internal runtime implementation using exact approved lesson-plan fixtures; shared execution routing, Artifact semantics, Model Gateway and release contracts remain single-writer.",
      "writable": [
        "apps/api/ppt_runtime/**",
        "apps/api/assets/ppt_runtime_contracts.py",
        "apps/api/assets/ppt_runtime_port.py",
        "apps/api/assets/pptx_writer.py",
        "scripts/golden_courseware_ppt_outputs.py",
        "tests/unit/ppt_runtime/**",
        "tests/unit/test_ppt_runtime_service.py",
        "tests/integration/ppt_runtime_*.py",
        "tests/integration/test_ppt_runtime*.py",
        "tests/contract/test_ppt_runtime_contract.py",
        "tests/contract/test_golden_ppt_runtime_projection.py",
        "contracts/fixtures/parallel-inputs/ppt/**"
      ],
      "readonly": [
        "contracts/api-surface.openapi.yaml",
        "contracts/generated/**",
        "contracts/full-chain-freeze.json",
        "contracts/page-api-fact-matrix.json",
        "contracts/fixtures/contract-freeze/**",
        "contracts/fixtures/workflow-node-generation-bindings/**",
        "contracts/fixtures/primary-math-courseware-package/**"
      ],
      "forbidden": [
        "apps/web/**",
        "contracts/api-surface.openapi.yaml",
        "contracts/planned-api-surface.openapi.yaml",
        "contracts/generated/**",
        "workflow/builtin/primary_math_courseware/**",
        "workflow/definition/**",
        "apps/api/node_execution/**",
        "apps/api/artifacts/**",
        "apps/api/model_gateway/**",
        "apps/api/video_runtime/**"
      ],
      "contract_change_required": true
    },
    {
      "track_key": "video",
      "role": "Complete video internal runtime implementation using exact IntroSelection fixtures, including real TTS, subtitles, timeline and final MP4; shared execution routing, Artifact semantics, Model Gateway and release contracts remain single-writer.",
      "writable": [
        "apps/api/video_runtime/**",
        "tests/unit/video_runtime/**",
        "tests/integration/test_video_runtime*.py",
        "tests/contract/test_video_golden_node_release.py",
        "contracts/fixtures/parallel-inputs/video/**"
      ],
      "readonly": [
        "contracts/api-surface.openapi.yaml",
        "contracts/generated/**",
        "contracts/full-chain-freeze.json",
        "contracts/page-api-fact-matrix.json",
        "contracts/fixtures/contract-freeze/**",
        "contracts/fixtures/workflow-node-generation-bindings/**",
        "contracts/fixtures/primary-math-courseware-package/**"
      ],
      "forbidden": [
        "apps/web/**",
        "contracts/api-surface.openapi.yaml",
        "contracts/planned-api-surface.openapi.yaml",
        "contracts/generated/**",
        "workflow/builtin/primary_math_courseware/**",
        "workflow/definition/**",
        "apps/api/node_execution/**",
        "apps/api/artifacts/**",
        "apps/api/model_gateway/**",
        "apps/api/ppt_runtime/**"
      ],
      "contract_change_required": true
    },
    {
      "track_key": "mainline",
      "role": "Material, lesson division, lesson plan and intro domain implementation using the frozen shared contract; shared node execution, Artifact and API changes require a prior Contract Change.",
      "writable": [
        "apps/api/lessons/**",
        "apps/api/uploads/**",
        "apps/api/assets/material_evidence.py",
        "tests/unit/lessons/**",
        "tests/integration/mainline/**",
        "contracts/fixtures/parallel-inputs/mainline/**"
      ],
      "readonly": [
        "contracts/api-surface.openapi.yaml",
        "contracts/generated/**",
        "contracts/full-chain-freeze.json",
        "contracts/page-api-fact-matrix.json",
        "contracts/fixtures/contract-freeze/**",
        "contracts/fixtures/workflow-node-generation-bindings/**",
        "contracts/fixtures/primary-math-courseware-package/**"
      ],
      "forbidden": [
        "apps/web/**",
        "contracts/api-surface.openapi.yaml",
        "contracts/planned-api-surface.openapi.yaml",
        "contracts/generated/**",
        "workflow/builtin/primary_math_courseware/**",
        "workflow/definition/**",
        "apps/api/node_execution/**",
        "apps/api/artifacts/**",
        "apps/api/model_gateway/**",
        "apps/api/ppt_runtime/**",
        "apps/api/video_runtime/**"
      ],
      "contract_change_required": true
    }
  ]
}