{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/projection-template.schema.json",
  "title": "ProjectionTemplateSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_key",
    "title",
    "source_definition_ref",
    "output_format",
    "renderer_id",
    "allowed_variables"
  ],
  "properties": {
    "projection_key": {"$ref": "#/$defs/key"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "source_definition_ref": {"$ref": "#/$defs/outputRef"},
    "output_format": {"enum": ["prompt_text", "markdown", "docx", "pptx", "pdf", "video_script"]},
    "renderer_id": {"$ref": "#/$defs/key"},
    "template": {"type": "string", "minLength": 1},
    "allowed_variables": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/key"}
    },
    "teacher_visible": {"type": "boolean", "default": true}
  },
  "allOf": [
    {
      "if": {"properties": {"output_format": {"enum": ["prompt_text", "markdown"]}}},
      "then": {"required": ["template"]}
    }
  ],
  "$defs": {
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
    "outputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"const": "content_definition"}
      }
    }
  }
}
