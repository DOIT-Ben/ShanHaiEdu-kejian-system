{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/style-preset.schema.json",
  "title": "StylePresetSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["preset_key", "title", "modalities", "visual_language"],
  "properties": {
    "preset_key": {"$ref": "#/$defs/key"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "modalities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["image", "video", "presentation"]}
    },
    "visual_language": {"type": "string", "minLength": 1},
    "palette": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "mood": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "texture": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "negative_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "preview_asset_ref": {"type": "string", "minLength": 1},
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {"$ref": "#/$defs/imageExtension"},
        "video": {"$ref": "#/$defs/videoExtension"},
        "presentation": {"$ref": "#/$defs/presentationExtension"}
      }
    }
  },
  "$defs": {
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
    "stringList": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "imageExtension": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "medium": {"type": "string"},
        "composition_preferences": {"$ref": "#/$defs/stringList"},
        "lighting": {"$ref": "#/$defs/stringList"}
      }
    },
    "videoExtension": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "motion_language": {"type": "string"},
        "camera_language": {"type": "string"},
        "pacing": {"type": "string"},
        "transition_style": {"type": "string"}
      }
    },
    "presentationExtension": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background_policy": {"enum": ["white", "solid", "image", "template"]},
        "typography": {"type": "string"},
        "layout_density": {"enum": ["sparse", "balanced", "dense"]},
        "illustration_style": {"type": "string"}
      }
    }
  }
}
