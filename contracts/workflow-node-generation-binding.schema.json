{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/workflow-node-generation-binding.schema.json",
  "title": "WorkflowNodeGenerationBindingCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "catalog_key",
    "workflow_key",
    "semantic_version",
    "external_input_contract_refs",
    "validator_descriptors",
    "nodes"
  ],
  "properties": {
    "api_version": {"const": "shanhai.workflow-node-generation-binding/v2"},
    "catalog_key": {"$ref": "#/$defs/key"},
    "workflow_key": {"$ref": "#/$defs/key"},
    "semantic_version": {"$ref": "#/$defs/semanticVersion"},
    "external_input_contract_refs": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/contractRef"}
    },
    "validator_descriptors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/validatorDescriptor"}
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/node"}
    }
  },
  "$defs": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{1,159}$"
    },
    "contractRef": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]{1,79}:[a-z][a-z0-9_.-]{1,159}$"
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "artifactType": {
      "type": "string",
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9_.-]+$"
    },
    "creationPackageKeyPrefix": {
      "type": "string",
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9_.-]+$"
    },
    "lessonArtifactKeyPrefix": {
      "type": "string",
      "maxLength": 79,
      "pattern": "^[a-z][a-z0-9_.-]+$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "validatorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "semantic_version", "implementation_digest"],
      "properties": {
        "key": {"$ref": "#/$defs/key"},
        "semantic_version": {"$ref": "#/$defs/semanticVersion"},
        "implementation_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "validatorDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "semantic_version",
        "implementation_digest",
        "implementation_status"
      ],
      "properties": {
        "key": {"$ref": "#/$defs/key"},
        "semantic_version": {"$ref": "#/$defs/semanticVersion"},
        "implementation_digest": {"$ref": "#/$defs/digest"},
        "implementation_status": {"const": "contract_only"}
      }
    },
    "contentDefinitionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"const": "content_definition"}
      }
    },
    "generationTemplateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"const": "generation_template"}
      }
    },
    "promptExposurePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "teacher_business_prompt",
        "internal_template",
        "output_contract",
        "validation_and_repair",
        "provider_format",
        "structure_change_authority"
      ],
      "properties": {
        "teacher_business_prompt": {
          "enum": ["editable", "hidden", "not_applicable"]
        },
        "internal_template": {"const": "server_only"},
        "output_contract": {"const": "server_only"},
        "validation_and_repair": {"const": "server_only"},
        "provider_format": {"const": "server_only"},
        "structure_change_authority": {"const": "administrator_release_only"}
      }
    },
    "instructionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_key",
        "content_kind",
        "semantic_version",
        "role",
        "exposure"
      ],
      "properties": {
        "content_key": {"$ref": "#/$defs/key"},
        "content_kind": {
          "enum": ["handbook", "rule_set", "anchor_library", "style_preset"]
        },
        "semantic_version": {"$ref": "#/$defs/semanticVersion"},
        "role": {"enum": ["method", "quality", "safety", "anchor", "style"]},
        "exposure": {"const": "server_only"}
      }
    },
    "instructionPolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "refs"],
          "properties": {
            "mode": {"const": "none"},
            "refs": {"type": "array", "maxItems": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "refs"],
          "properties": {
            "mode": {"const": "declared"},
            "refs": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100,
              "items": {"$ref": "#/$defs/instructionRef"}
            }
          }
        }
      ]
    },
    "contextPolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "allowed_sources", "forbidden_sources"],
          "properties": {
            "mode": {"const": "none"},
            "allowed_sources": {"type": "array", "maxItems": 0},
            "forbidden_sources": {"type": "array", "maxItems": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "allowed_sources", "forbidden_sources"],
          "properties": {
            "mode": {"const": "declared"},
            "allowed_sources": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100,
              "items": {"$ref": "#/$defs/key"}
            },
            "forbidden_sources": {
              "type": "array",
              "maxItems": 100,
              "items": {"$ref": "#/$defs/key"}
            }
          }
        }
      ]
    },
    "referenceRole": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_key",
        "requirement",
        "media_types",
        "min_items",
        "max_items",
        "order_mode",
        "allowed_sources",
        "provider_exposure"
      ],
      "properties": {
        "role_key": {"$ref": "#/$defs/key"},
        "requirement": {"enum": ["optional", "required"]},
        "media_types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {"enum": ["image", "video", "audio", "document"]}
        },
        "min_items": {"type": "integer", "minimum": 0, "maximum": 100},
        "max_items": {"type": "integer", "minimum": 1, "maximum": 100},
        "order_mode": {"enum": ["stable_by_role_then_version", "user_selected"]},
        "allowed_sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "enum": [
              "artifact_version",
              "asset_slot_current",
              "creation_result",
              "user_upload"
            ]
          }
        },
        "provider_exposure": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "enum": ["signed_url", "provider_file_id", "inline_bytes", "derived_text"]
          }
        }
      }
    },
    "referenceAssetPolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "roles"],
          "properties": {
            "mode": {"const": "none"},
            "roles": {"type": "array", "maxItems": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "roles"],
          "properties": {
            "mode": {"enum": ["optional", "required"]},
            "roles": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": {"$ref": "#/$defs/referenceRole"}
            }
          }
        }
      ]
    },
    "repairPolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {"mode": {"const": "none"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "repair_template_ref", "max_attempts"],
          "properties": {
            "mode": {"const": "template"},
            "repair_template_ref": {"$ref": "#/$defs/generationTemplateRef"},
            "max_attempts": {"type": "integer", "minimum": 1, "maximum": 3}
          }
        }
      ]
    },
    "approvalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "required_before_downstream"],
      "properties": {
        "mode": {"enum": ["none", "human_required", "policy_allowed"]},
        "required_before_downstream": {"type": "boolean"}
      }
    },
    "pointerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "pointer"],
      "properties": {
        "source": {"enum": ["output", "item", "runtime"]},
        "pointer": {"type": "string", "maxLength": 2048}
      }
    },
    "outputPointerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "pointer"],
      "properties": {
        "source": {"const": "output"},
        "pointer": {"type": "string", "maxLength": 2048}
      }
    },
    "constantProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "value"],
      "properties": {
        "source": {"const": "constant"},
        "value": {}
      }
    },
    "intrinsicProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "name"],
      "properties": {
        "source": {"const": "intrinsic"},
        "name": {"const": "item_position"}
      }
    },
    "valueProjection": {
      "oneOf": [
        {"$ref": "#/$defs/pointerProjection"},
        {"$ref": "#/$defs/constantProjection"},
        {"$ref": "#/$defs/intrinsicProjection"}
      ]
    },
    "rootOutputProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "pointer"],
      "properties": {
        "source": {"const": "output"},
        "pointer": {"const": ""}
      }
    },
    "artifactIdentity": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy", "artifact_key"],
          "properties": {
            "strategy": {"const": "project_singleton"},
            "artifact_key": {"$ref": "#/$defs/key"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy", "artifact_key_prefix"],
          "properties": {
            "strategy": {"const": "lesson_unit_singleton"},
            "artifact_key_prefix": {"$ref": "#/$defs/lessonArtifactKeyPrefix"}
          }
        }
      ]
    },
    "impactScope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {"mode": {"const": "all"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "selector", "keys"],
          "properties": {
            "mode": {"const": "keyed"},
            "selector": {"const": "lesson_key"},
            "keys": {"$ref": "#/$defs/valueProjection"}
          }
        }
      ]
    },
    "relationBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_binding", "relation_type", "binding_key", "impact_scope"],
      "properties": {
        "source_binding": {"$ref": "#/$defs/contractRef"},
        "relation_type": {"enum": ["derives_from", "references", "constrains", "supersedes"]},
        "binding_key": {"$ref": "#/$defs/key"},
        "optional": {"type": "boolean", "default": false},
        "impact_scope": {"$ref": "#/$defs/impactScope"}
      }
    },
    "artifactPersistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "artifact_type",
        "branch_key",
        "content_definition_ref",
        "content",
        "relations"
      ],
      "properties": {
        "identity": {"$ref": "#/$defs/artifactIdentity"},
        "artifact_type": {"$ref": "#/$defs/artifactType"},
        "branch_key": {"$ref": "#/$defs/key"},
        "content_definition_ref": {"$ref": "#/$defs/contentDefinitionRef"},
        "content": {"$ref": "#/$defs/rootOutputProjection"},
        "relations": {
          "type": "array",
          "maxItems": 100,
          "items": {"$ref": "#/$defs/relationBinding"}
        }
      }
    },
    "creationPackageKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "prefix"],
      "properties": {
        "strategy": {"const": "source_artifact_version"},
        "prefix": {"$ref": "#/$defs/creationPackageKeyPrefix"}
      }
    },
    "authorizedReferenceAssetsProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "pointer"],
      "properties": {
        "source": {"const": "runtime"},
        "pointer": {"const": "/reference_assets"}
      }
    },
    "constantReferenceAssetsProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "value"],
      "properties": {
        "source": {"const": "constant"},
        "value": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["asset_version_id", "role"],
            "properties": {
              "asset_version_id": {"type": "string", "format": "uuid"},
              "role": {"type": "string", "minLength": 1, "maxLength": 160}
            }
          }
        }
      }
    },
    "referenceAssetsProjection": {
      "oneOf": [
        {"$ref": "#/$defs/constantReferenceAssetsProjection"},
        {"$ref": "#/$defs/authorizedReferenceAssetsProjection"}
      ]
    },
    "creationPackageItemMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_key",
        "position",
        "title",
        "business_prompt",
        "reference_assets",
        "output_spec",
        "target_slot",
        "consistency_key"
      ],
      "properties": {
        "item_key": {"$ref": "#/$defs/valueProjection"},
        "position": {"$ref": "#/$defs/valueProjection"},
        "title": {"$ref": "#/$defs/valueProjection"},
        "business_prompt": {"$ref": "#/$defs/valueProjection"},
        "reference_assets": {"$ref": "#/$defs/referenceAssetsProjection"},
        "output_spec": {"$ref": "#/$defs/valueProjection"},
        "target_slot": {"$ref": "#/$defs/valueProjection"},
        "consistency_key": {"$ref": "#/$defs/valueProjection"}
      }
    },
      "targetRules": {
        "type": "object",
        "additionalProperties": false,
        "required": ["replace_modes", "allow_download", "target_slot_prefix"],
      "properties": {
        "replace_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["reject_if_occupied", "replace_active", "append"]}
        },
        "allow_download": {"type": "boolean"},
        "target_slot_prefix": {
          "type": "string",
          "maxLength": 159,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*\\.$"
        }
      }
    },
    "creationPackagePersistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_type",
        "package_key",
        "items_pointer",
        "item_mapping",
        "target_rules"
      ],
      "properties": {
        "package_type": {"enum": ["image", "video", "presentation"]},
        "package_key": {"$ref": "#/$defs/creationPackageKey"},
        "items_pointer": {"type": "string", "maxLength": 2048},
        "item_mapping": {"$ref": "#/$defs/creationPackageItemMapping"},
        "target_rules": {"$ref": "#/$defs/targetRules"}
      }
    },
    "approvalCompletion": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "collection_pointer", "stable_key_field"],
          "properties": {
            "kind": {"const": "lesson_unit_sync"},
            "collection_pointer": {"const": "/lesson_units"},
            "stable_key_field": {"const": "lesson_unit_key"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "source_input_ref"],
          "properties": {
            "kind": {"const": "workflow_gate"},
            "source_input_ref": {"$ref": "#/$defs/contractRef"}
          }
        }
      ]
    },
    "outputPersistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact"],
      "properties": {
        "artifact": {"$ref": "#/$defs/artifactPersistence"},
        "creation_package": {"$ref": "#/$defs/creationPackagePersistence"},
        "approval_completion": {"$ref": "#/$defs/approvalCompletion"}
      }
    },
    "qualityReportPersistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_input_ref", "report_ref", "validator_refs", "mapping"],
      "properties": {
        "source_input_ref": {"$ref": "#/$defs/contractRef"},
        "report_ref": {"$ref": "#/$defs/contractRef"},
        "supporting_input_refs": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/contractRef"}
        },
        "validator_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/validatorRef"}
        },
        "mapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["conclusion", "findings", "evidence"],
          "properties": {
            "conclusion": {"$ref": "#/$defs/outputPointerProjection"},
            "findings": {"$ref": "#/$defs/outputPointerProjection"},
            "evidence": {"$ref": "#/$defs/outputPointerProjection"}
          }
        }
      }
    },
    "qualityRequirement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {"mode": {"const": "none"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "report_refs", "accepted_conclusions"],
          "properties": {
            "mode": {"const": "reports"},
            "report_refs": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/contractRef"}
            },
            "accepted_conclusions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"enum": ["passed"]}
            }
          }
        }
      ]
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_key",
        "title",
        "phase",
        "execution_kind",
        "execution_scope",
        "branch_key",
        "entrypoint",
        "dependencies",
        "input_contract_refs",
        "output_contract_refs",
        "prompt_exposure_policy",
        "instruction_policy",
        "context_policy",
        "reference_asset_policy",
        "validator_refs",
        "repair_policy",
        "approval_policy"
      ],
      "properties": {
        "node_key": {"$ref": "#/$defs/key"},
        "title": {"type": "string", "minLength": 1, "maxLength": 255},
        "phase": {
          "enum": [
            "material",
            "lesson",
            "lesson_plan",
            "intro",
            "ppt",
            "video",
            "audio",
            "delivery"
          ]
        },
        "execution_kind": {
          "enum": ["model_generation", "deterministic", "human_gate"]
        },
        "execution_scope": {"enum": ["project", "lesson_unit"]},
        "branch_key": {
          "type": ["string", "null"],
          "pattern": "^[a-z][a-z0-9_.-]{1,79}$"
        },
        "entrypoint": {"type": "boolean"},
        "dependencies": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 100,
          "items": {"$ref": "#/$defs/key"}
        },
        "model_capability": {
          "type": "string",
          "pattern": "^(text|vision|image|video|audio)\\.[a-z][a-z0-9_.-]{1,159}$"
        },
        "generation_template_ref": {"$ref": "#/$defs/generationTemplateRef"},
        "executor_ref": {
          "type": "string",
          "pattern": "^executor\\.[a-z][a-z0-9_.-]{1,159}$"
        },
        "input_contract_refs": {
          "type": "array",
          "maxItems": 100,
          "items": {"$ref": "#/$defs/contractRef"}
        },
        "optional_input_contract_refs": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 100,
          "items": {"$ref": "#/$defs/contractRef"}
        },
        "output_contract_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {"$ref": "#/$defs/contractRef"}
        },
        "prompt_exposure_policy": {"$ref": "#/$defs/promptExposurePolicy"},
        "instruction_policy": {"$ref": "#/$defs/instructionPolicy"},
        "context_policy": {"$ref": "#/$defs/contextPolicy"},
        "reference_asset_policy": {"$ref": "#/$defs/referenceAssetPolicy"},
        "validator_refs": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 100,
          "items": {"$ref": "#/$defs/validatorRef"}
        },
        "repair_policy": {"$ref": "#/$defs/repairPolicy"},
        "approval_policy": {"$ref": "#/$defs/approvalPolicy"},
        "output_persistence": {"$ref": "#/$defs/outputPersistence"},
        "quality_report_persistence": {"$ref": "#/$defs/qualityReportPersistence"},
        "quality_requirement": {"$ref": "#/$defs/qualityRequirement"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"execution_scope": {"const": "project"}},
            "required": ["execution_scope"]
          },
          "then": {
            "properties": {
              "branch_key": {"enum": ["material", "lesson_division", "delivery"]}
            }
          }
        },
        {
          "if": {
            "properties": {"execution_scope": {"const": "lesson_unit"}},
            "required": ["execution_scope"]
          },
          "then": {
            "properties": {
              "branch_key": {
                "enum": ["lesson_plan", "intro_options", "ppt", "video"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {"execution_kind": {"const": "model_generation"}},
            "required": ["execution_kind"]
          },
          "then": {
            "required": ["model_capability", "generation_template_ref", "output_persistence"],
            "not": {
              "anyOf": [
                {"required": ["executor_ref"]},
                {"required": ["quality_report_persistence"]},
                {"required": ["quality_requirement"]}
              ]
            }
          }
        },
        {
          "if": {
            "properties": {"execution_kind": {"const": "deterministic"}},
            "required": ["execution_kind"]
          },
          "then": {
            "required": ["executor_ref"],
            "not": {
              "anyOf": [
                {"required": ["model_capability"]},
                {"required": ["generation_template_ref"]},
