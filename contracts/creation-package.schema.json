{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/creation-package.schema.json",
  "title": "CreationPackage",
  "oneOf": [
    {"$ref": "#/$defs/legacy_package"},
    {"$ref": "#/$defs/current_package"}
  ],
  "$defs": {
    "reference_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_version_id", "role"],
      "properties": {
        "asset_version_id": {"type": "string", "format": "uuid"},
        "role": {"type": "string", "minLength": 1}
      }
    },
    "legacy_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "position", "title", "prompt", "output_spec"],
      "properties": {
        "item_key": {"type": "string", "minLength": 1},
        "position": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "prompt": {"type": "object", "additionalProperties": true},
        "reference_assets": {
          "type": "array",
          "items": {"$ref": "#/$defs/reference_asset"}
        },
        "output_spec": {"type": "object", "additionalProperties": true},
        "target_slot_key": {"type": ["string", "null"]},
        "consistency_key": {"type": ["string", "null"]}
      }
    },
    "legacy_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_id", "package_type", "status", "source", "items", "created_at"],
      "properties": {
        "package_id": {"type": "string", "format": "uuid"},
        "package_type": {"enum": ["image", "video", "presentation"]},
        "status": {"enum": ["building", "ready", "invalid", "expired"]},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project_id", "node_run_id"],
          "properties": {
            "project_id": {"type": "string", "format": "uuid"},
            "lesson_unit_id": {"type": ["string", "null"], "format": "uuid"},
            "node_run_id": {"type": "string", "format": "uuid"},
            "is_stale": {"type": "boolean", "default": false}
          }
        },
        "style_contract": {"type": ["object", "null"], "additionalProperties": true},
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/legacy_item"}
        },
        "target_rules": {"type": "object", "additionalProperties": true},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "current_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_key",
        "position",
        "title",
        "business_prompt",
        "prompt",
        "output_spec",
        "target_slot_key"
      ],
      "properties": {
        "item_key": {"type": "string", "minLength": 1, "maxLength": 160},
        "position": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "business_prompt": {"type": "string", "minLength": 1, "maxLength": 50000},
        "prompt": {"type": "object", "additionalProperties": true},
        "reference_assets": {
          "type": "array",
          "maxItems": 20,
          "items": {"$ref": "#/$defs/reference_asset"}
        },
        "output_spec": {"type": "object", "additionalProperties": true},
        "target_slot_key": {"type": "string", "minLength": 1, "maxLength": 160},
        "consistency_key": {"type": ["string", "null"], "maxLength": 160}
      }
    },
    "current_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "package_id",
        "package_type",
        "status",
        "source",
        "context_snapshot_id",
        "source_prompt_snapshot_id",
        "items",
        "target_rules",
        "content_hash",
        "created_at"
      ],
      "properties": {
        "schema_version": {"const": "2.0"},
        "package_id": {"type": "string", "format": "uuid"},
        "package_type": {"enum": ["image", "video", "presentation"]},
        "status": {"enum": ["building", "ready", "invalid", "expired"]},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project_id", "workflow_run_id", "source_node_run_id"],
          "properties": {
            "project_id": {"type": "string", "format": "uuid"},
            "workflow_run_id": {"type": "string", "format": "uuid"},
            "lesson_unit_id": {"type": ["string", "null"], "format": "uuid"},
            "source_node_run_id": {"type": "string", "format": "uuid"},
            "is_stale": {"type": "boolean", "default": false}
          }
        },
        "context_snapshot_id": {"type": "string", "format": "uuid"},
        "source_prompt_snapshot_id": {"type": "string", "format": "uuid"},
        "style_contract": {"type": ["object", "null"], "additionalProperties": true},
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/current_item"}
        },
        "target_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["replace_modes"],
          "properties": {
            "replace_modes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"enum": ["reject_if_occupied", "replace_active", "append"]}
            },
            "allow_download": {"type": "boolean", "default": true}
          }
        },
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
