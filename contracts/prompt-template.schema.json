{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/prompt-template.schema.json",
  "title": "PromptTemplateSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_key",
    "title",
    "model_capability",
    "input_definition_ref",
    "output_definition_ref",
    "sections",
    "context_bindings",
    "user_edit_policy"
  ],
  "properties": {
    "template_key": {"$ref": "#/$defs/key"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "model_capability": {"$ref": "#/$defs/key"},
    "input_definition_ref": {"$ref": "#/$defs/inputRef"},
    "output_definition_ref": {"$ref": "#/$defs/outputRef"},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/section"}
    },
    "context_bindings": {
      "type": "array",
      "items": {"$ref": "#/$defs/contextBinding"}
    },
    "user_edit_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "max_chars"],
      "properties": {
        "mode": {"const": "replace_editable_layer"},
        "max_chars": {"type": "integer", "minimum": 1, "maximum": 100000}
      }
    }
  },
  "$defs": {
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
    "itemRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"type": "string"}
      }
    },
    "inputRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "input_definition"}}}
      ]
    },
    "outputRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "content_definition"}}}
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_key", "layer", "content", "editable", "visible_to_teacher"],
      "properties": {
        "section_key": {"$ref": "#/$defs/key"},
        "layer": {
          "enum": ["role", "task", "method", "context_instruction", "user_guidance", "quality_gate"]
        },
        "content": {"type": "string", "minLength": 1},
        "editable": {"type": "boolean"},
        "visible_to_teacher": {"type": "boolean"}
      }
    },
    "contextBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_key", "source", "required", "exposure", "max_items", "max_bytes"],
      "properties": {
        "binding_key": {"$ref": "#/$defs/key"},
        "source": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
        "required": {"type": "boolean"},
        "exposure": {"enum": ["full", "summary", "hidden"]},
        "max_items": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_bytes": {"type": "integer", "minimum": 1, "maximum": 10000000}
      }
    }
  }
}
