{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/full-chain-freeze.schema.json",
  "title": "ShanHaiEdu Full Chain Freeze",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "contract_key",
    "status",
    "source_release",
    "source_files",
    "global_invariants",
    "branches",
    "change_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "shanhai.full-chain-freeze/v1"
    },
    "contract_key": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["frozen_for_parallel_development"]
    },
    "source_release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_key", "semantic_version", "immutability"],
      "properties": {
        "package_key": {"type": "string", "minLength": 1},
        "semantic_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "immutability": {"const": "forward_only"}
      }
    },
    "source_files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_catalog", "content_manifest", "generation_source", "ppt_handbook", "video_handbook"],
      "properties": {
        "workflow_catalog": {"$ref": "#/$defs/repositoryPath"},
        "content_manifest": {"$ref": "#/$defs/repositoryPath"},
        "generation_source": {"$ref": "#/$defs/repositoryPath"},
        "ppt_handbook": {"$ref": "#/$defs/repositoryPath"},
        "video_handbook": {"$ref": "#/$defs/repositoryPath"}
      }
    },
    "global_invariants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "branches": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/branch"}
    },
    "change_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["historical_release", "shared_contract_owner", "consumer_change_process"],
      "properties": {
        "historical_release": {"const": "never_modify_in_place"},
        "shared_contract_owner": {"const": "single_writer"},
        "consumer_change_process": {"const": "contract_change_then_rebase"}
      }
    }
  },
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_key",
        "scope",
        "entry_contract_refs",
        "terminal_contract_refs",
        "required_node_sequence",
        "golden_assertions"
      ],
      "properties": {
        "branch_key": {
          "enum": ["mainline", "ppt", "video", "delivery"]
        },
        "scope": {
          "enum": ["project", "lesson_unit", "mixed"]
        },
        "entry_contract_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "terminal_contract_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "required_node_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nodeReference"}
        },
        "golden_assertions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "nodeReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_key", "expected_execution_kind", "expected_scope", "freeze_level"],
      "properties": {
        "node_key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
        "expected_execution_kind": {
          "enum": ["model_generation", "deterministic", "human_gate"]
        },
        "expected_scope": {
          "enum": ["project", "lesson_unit"]
        },
        "freeze_level": {
          "const": "existing_catalog_exact"
        },
        "required_runtime_outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}