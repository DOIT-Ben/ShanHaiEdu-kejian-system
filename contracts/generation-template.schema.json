{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/contracts/generation-template.schema.json",
  "title": "GenerationTemplateSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_key",
    "title",
    "model_capability",
    "input_definition_ref",
    "prompt_template_ref",
    "output_definition_ref",
    "projection_refs"
  ],
  "properties": {
    "template_key": {"$ref": "#/$defs/key"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "model_capability": {"$ref": "#/$defs/key"},
    "input_definition_ref": {"$ref": "#/$defs/inputRef"},
    "prompt_template_ref": {"$ref": "#/$defs/promptRef"},
    "output_definition_ref": {"$ref": "#/$defs/outputRef"},
    "style_preset_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/styleRef"}
    },
    "projection_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "template_ref"],
        "properties": {
          "role": {"enum": ["teacher_view", "provider_request", "export"]},
          "template_ref": {"$ref": "#/$defs/projectionRef"}
        }
      }
    }
  },
  "$defs": {
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,159}$"},
    "itemRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "kind"],
      "properties": {
        "item_key": {"$ref": "#/$defs/key"},
        "kind": {"type": "string"}
      }
    },
    "inputRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "input_definition"}}}
      ]
    },
    "promptRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "prompt_template"}}}
      ]
    },
    "outputRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "content_definition"}}}
      ]
    },
    "styleRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "style_preset"}}}
      ]
    },
    "projectionRef": {
      "allOf": [
        {"$ref": "#/$defs/itemRef"},
        {"properties": {"kind": {"const": "projection_template"}}}
      ]
    }
  }
}
