# This template deliberately omits the required signing-secret assignment.
# Generate 32 random bytes with an approved CSPRNG, encode them as exactly
# 64 hexadecimal characters, and write the assignment directly to the root-only
# deployment file without displaying or logging the value.
SHANHAI_PROVIDER_MEDIA_ROOT=/srv/shanhaiedu/runtime/provider-media
SHANHAI_PROVIDER_MEDIA_MAX_TTL_SECONDS=300
SHANHAI_PROVIDER_MEDIA_MAX_FILE_BYTES=10485760
