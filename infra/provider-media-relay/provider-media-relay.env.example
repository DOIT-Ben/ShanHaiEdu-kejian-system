# This is a template. Copy it to /etc/shanhaiedu/provider-media-relay.env,
# replace the placeholder, then set mode 0600 and owner root:root.
SHANHAI_PROVIDER_MEDIA_ROOT=/srv/shanhaiedu/runtime/provider-media
SHANHAI_PROVIDER_MEDIA_SIGNING_SECRET=PLACEHOLDER_REPLACE_WITH_A_UNIQUE_64_HEX_CHARACTER_SECRET
SHANHAI_PROVIDER_MEDIA_MAX_TTL_SECONDS=300
SHANHAI_PROVIDER_MEDIA_MAX_FILE_BYTES=10485760
