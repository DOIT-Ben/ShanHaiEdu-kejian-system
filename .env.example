# Copy to .env for local development. These values are local-only examples.
SHANHAI_ENVIRONMENT=development
SHANHAI_LOG_LEVEL=INFO
SHANHAI_API_HOST=127.0.0.1
SHANHAI_API_PORT=8000
SHANHAI_DATABASE_URL=postgresql://shanhai:shanhai-local-only@127.0.0.1:55432/shanhai
SHANHAI_REDIS_URL=redis://127.0.0.1:56379/0
SHANHAI_OBJECT_STORAGE_HEALTH_URL=http://127.0.0.1:59000/minio/health/ready
SHANHAI_OBJECT_STORAGE_ENDPOINT=127.0.0.1:59000
SHANHAI_OBJECT_STORAGE_ACCESS_KEY=shanhai-local
SHANHAI_OBJECT_STORAGE_SECRET_KEY=shanhai-local-only
SHANHAI_OBJECT_STORAGE_SECURE=false
SHANHAI_OBJECT_STORAGE_BUCKET=shanhaiedu
SHANHAI_DEPENDENCY_TIMEOUT_SECONDS=2.0
SHANHAI_MATERIAL_PARSE_MAX_PAGES=500
SHANHAI_MATERIAL_PARSE_MAX_TEXT_CHARS=5000000
SHANHAI_MATERIAL_PARSE_MAX_TEXT_BLOCKS=100000
SHANHAI_MATERIAL_PARSE_MAX_IMAGE_REFERENCES=10000
SHANHAI_MATERIAL_PARSE_TIMEOUT_SECONDS=30

# Production Session/CSRF bootstrap. Configure the first four values together.
# Keep access codes and CSRF secrets in the deployment secret manager, not in this file.
# List values use JSON arrays; origins are exact scheme + host + optional port values.
# SHANHAI_SESSION_ACCESS_CODE=<opaque-secret-at-least-24-characters>
# SHANHAI_SESSION_CSRF_SECRET=<random-secret-at-least-32-characters>
# SHANHAI_SESSION_TEACHER_PRINCIPAL_ID=01960000-0000-7000-8000-000000000002
# SHANHAI_SESSION_ALLOWED_ORIGINS=["https://teacher.example.edu"]
# SHANHAI_SESSION_COOKIE_SECURE=true
# SHANHAI_SESSION_TTL_SECONDS=3600
# SHANHAI_SESSION_LOGIN_MAX_FAILURES=5
# SHANHAI_SESSION_LOGIN_WINDOW_SECONDS=300
# SHANHAI_SESSION_TRUSTED_PROXY_HOSTS=["10.0.0.0/8","192.0.2.10"]

# Optional real text Provider route. Keep this disabled in the default quick start.
# Aliyun tasks load the approved mapping from the repository-external file documented by
# the model gateway entry in docs/backend/README.md.
# Standard mapping example; do not enable it in ordinary CI or deterministic tests:
# MODEL_GATEWAY_BASE_URL=https://newapi.doitbenai.cloud/v1
# MODEL_GATEWAY_API_KEY=
# SHANHAI_TEXT_PROVIDER_NAME=newapi
# SHANHAI_TEXT_PROVIDER_BASE_URL=https://newapi.doitbenai.cloud/v1
# SHANHAI_TEXT_PROVIDER_MODEL=deepseek
# SHANHAI_TEXT_PROVIDER_SECRET_ENV=MODEL_GATEWAY_API_KEY
# SHANHAI_TEXT_PROVIDER_TIMEOUT_SECONDS=120
SHANHAI_TEXT_PROVIDER_NAME=
SHANHAI_TEXT_PROVIDER_BASE_URL=
SHANHAI_TEXT_PROVIDER_MODEL=
SHANHAI_TEXT_PROVIDER_SECRET_ENV=
SHANHAI_TEXT_PROVIDER_TIMEOUT_SECONDS=30

# Optional real video Provider route. This is only for the explicit video-smoke command.
# SHANHAI_VIDEO_PROVIDER_NAME=newapi
# SHANHAI_VIDEO_PROVIDER_BASE_URL=https://newapi.doitbenai.cloud/v1
# SHANHAI_VIDEO_PROVIDER_MODEL=video-grok
# SHANHAI_VIDEO_PROVIDER_SECRET_ENV=MODEL_GATEWAY_API_KEY
# SHANHAI_VIDEO_PROVIDER_TIMEOUT_SECONDS=120
SHANHAI_VIDEO_PROVIDER_NAME=
SHANHAI_VIDEO_PROVIDER_BASE_URL=
SHANHAI_VIDEO_PROVIDER_MODEL=
SHANHAI_VIDEO_PROVIDER_SECRET_ENV=
SHANHAI_VIDEO_PROVIDER_TIMEOUT_SECONDS=120

# Optional provider-media relay route for server-side image-to-video only.
# These values must match the root-only relay configuration on the target server.
# Keep the signing secret outside this file and ordinary CI.
SHANHAI_PROVIDER_MEDIA_ROOT=
SHANHAI_PROVIDER_MEDIA_PUBLIC_BASE_URL=
SHANHAI_PROVIDER_MEDIA_MAX_TTL_SECONDS=300
SHANHAI_PROVIDER_MEDIA_MAX_FILE_BYTES=10485760

# Compose dependency configuration. Never reuse these values outside local development.
SHANHAI_POSTGRES_USER=shanhai
SHANHAI_POSTGRES_PASSWORD=shanhai-local-only
SHANHAI_POSTGRES_DB=shanhai
SHANHAI_POSTGRES_PORT=55432
SHANHAI_REDIS_PORT=56379
SHANHAI_MINIO_ROOT_USER=shanhai-local
SHANHAI_MINIO_ROOT_PASSWORD=shanhai-local-only
SHANHAI_MINIO_API_PORT=59000
SHANHAI_MINIO_CONSOLE_PORT=59001

# Linux workspace container. compose.sh derives runtime UID/GID and worktree ports.
# Select rootless or dedicated-ecs in the host shell; do not persist that trust decision here.
SHANHAI_DEV_API_PORT=58000
SHANHAI_DEV_WORKSPACE_IMAGE=shanhaiedu-dev-workspace:2026.07-v2
