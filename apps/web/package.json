{
  "name": "@shanhaiedu/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/verify-production-build.mjs",
    "verify:production-build": "node scripts/verify-production-build.mjs",
    "preview": "vite preview",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b --pretty false",
    "generate:api": "corepack pnpm --dir ../.. contracts:generate && prettier --write src/generated/api-schema.ts",
    "test": "vitest run --maxWorkers=2",
    "test:watch": "vitest --maxWorkers=2",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:storybook:a11y": "node scripts/test-storybook-a11y.mjs",
    "test:e2e": "playwright test --workers=2",
    "test:e2e:runtime": "playwright test --config=playwright.runtime.config.ts",
    "release:check": "corepack pnpm generate:api && corepack pnpm format && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build:storybook && corepack pnpm test:storybook:a11y && corepack pnpm build && corepack pnpm test:e2e --project=chromium && corepack pnpm test:e2e:runtime --project=runtime-chromium"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.83.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "openapi-fetch": "0.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-router-dom": "^7.8.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.54.2",
    "@storybook/addon-a11y": "^9.1.1",
    "@storybook/addon-docs": "^9.1.1",
    "@storybook/addon-viewport": "9.0.8",
    "@storybook/react-vite": "^9.1.1",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "msw": "^2.10.4",
    "openapi-typescript": "7.8.0",
    "prettier": "^3.6.2",
    "storybook": "^9.1.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
